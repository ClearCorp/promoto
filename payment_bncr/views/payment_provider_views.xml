<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">BNCR Payment Gateway Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_credentials" position="inside">
                <group invisible="code != 'bncr'">
                    <field name="bncr_acquirer_id" 
                            required="code == 'bncr' and state != 'disabled'"
                            placeholder="99"/>
                    <field name="bncr_commerce_id" 
                            required="code == 'bncr' and state != 'disabled'"
                            placeholder="8056"/>
                    <field name="bncr_secret_key" 
                            required="code == 'bncr' and state != 'disabled'"
                            placeholder="clave_secreta_sha2"/>
                    <field name="bncr_gateway_url" 
                            required="code == 'bncr' and state != 'disabled'"
                            placeholder="https://integracion.alignetsac.com/"/>
                    <field name="bncr_modal_script_url"
                        required="code == 'bncr' and state != 'disabled'" 
                            placeholder="https://integracion.alignetsac.com/VPOS2/js/modalcomercio.js"/>
                </group>
            </group>
        </field>
    </record>

    <!-- Vista de formulario para transacciones con campos BNCR -->
    <record id="transaction_form_bncr" model="ir.ui.view">
        <field name="name">BNCR Transaction Form</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.payment_transaction_form"/>
        <field name="arch" type="xml">
            <page name="extra_info" position="after">
                <page string="BNCR Info" invisible="provider_code != 'bncr'">
                    <group>
                        <group string="Datos de Transacción BNCR">
                            <field name="bncr_acquirer_id" readonly="1"/>
                            <field name="bncr_commerce_id" readonly="1"/>
                            <field name="bncr_purchase_operation_number" readonly="1"/>
                            <field name="bncr_purchase_amount" readonly="1"/>
                            <field name="bncr_purchase_currency_code" readonly="1"/>
                            <field name="bncr_purchase_verification" readonly="1"/>
                        </group>
                        <group string="Datos de Envío">
                            <field name="bncr_shipping_first_name" readonly="1"/>
                            <field name="bncr_shipping_last_name" readonly="1"/>
                            <field name="bncr_shipping_email" readonly="1"/>
                            <field name="bncr_shipping_address" readonly="1"/>
                            <field name="bncr_shipping_zip" readonly="1"/>
                            <field name="bncr_shipping_city" readonly="1"/>
                            <field name="bncr_shipping_state" readonly="1"/>
                            <field name="bncr_shipping_country" readonly="1"/>
                        </group>
                        <group string="Campos Reservados">
                            <field name="bncr_reserved1" readonly="1"/>
                            <field name="bncr_reserved2" readonly="1"/>
                            <field name="bncr_reserved3" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
