<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">BNCR Payment Gateway Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_credentials" position="inside">
                <group invisible="code != 'bncr'">
                    <field name="bncr_acquirer_id" 
                            required="code == 'bncr' and state != 'disabled'"
                            placeholder="99"/>
                    <field name="bncr_commerce_id" 
                            required="code == 'bncr' and state != 'disabled'"
                            placeholder="8056"/>
                    <field name="bncr_secret_key" 
                            required="code == 'bncr' and state != 'disabled'"
                            placeholder="clave_secreta_sha2"/>
                    <field name="bncr_gateway_url" 
                            placeholder="https://integracion.alignetsac.com/"/>
                    <field name="bncr_modal_script_url"
                            placeholder="https://integracion.alignetsac.com/VPOS2/js/modalcomercio.js"/>
                </group>
            </group>
        </field>
    </record>
    
    <record id="payment_transaction_form_bncr" model="ir.ui.view">
        <field name="name">BNCR Transaction Form</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.payment_transaction_form" />
        <field name="arch" type="xml">
            <field name="provider_reference" position="after">
                <field name="bncr_acquirer_id" invisible="provider_code != 'bncr'"/>
                <field name="bncr_commerce_id" invisible="provider_code != 'bncr'"/>
                <field name="bncr_purchase_operation_number" invisible="provider_code != 'bncr'"/>
                <field name="bncr_purchase_amount" invisible="provider_code != 'bncr'"/>
                <field name="bncr_purchase_currency_code" invisible="provider_code != 'bncr'"/>
                <field name="bncr_purchase_verification" invisible="provider_code != 'bncr'"/>
                <field name="bncr_shipping_first_name" invisible="provider_code != 'bncr'"/>
                <field name="bncr_shipping_last_name" invisible="provider_code != 'bncr'"/>
                <field name="bncr_shipping_email" invisible="provider_code != 'bncr'"/>
                <field name="bncr_shipping_address" invisible="provider_code != 'bncr'"/>
                <field name="bncr_shipping_zip" invisible="provider_code != 'bncr'"/>
                <field name="bncr_shipping_city" invisible="provider_code != 'bncr'"/>
                <field name="bncr_shipping_state" invisible="provider_code != 'bncr'"/>
                <field name="bncr_shipping_country" invisible="provider_code != 'bncr'"/>
                <field name="bncr_reserved1" invisible="provider_code != 'bncr'"/>
                <field name="bncr_reserved2" invisible="provider_code != 'bncr'"/>
                <field name="bncr_reserved3" invisible="provider_code != 'bncr'"/>
            </field>
        </field>
    </record>
</odoo>
