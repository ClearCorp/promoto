<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">BNCR Payment Gateway Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_credentials" position="inside">
                <group invisible="code != 'bncr'">
                    <field name="bncr_acquirer_id" 
                            required="code == 'bncr' and state != 'disabled'"
                            placeholder="99"/>
                    <field name="bncr_commerce_id" 
                            required="code == 'bncr' and state != 'disabled'"
                            placeholder="8056"/>
                    <field name="bncr_secret_key" 
                            required="code == 'bncr' and state != 'disabled'"
                            placeholder="clave_secreta_sha2"/>
                    <field name="bncr_gateway_url" 
                            required="code == 'bncr' and state != 'disabled'"
                            placeholder="https://integracion.alignetsac.com/"/>
                    <field name="bncr_modal_script_url"
                        required="code == 'bncr' and state != 'disabled'" 
                            placeholder="https://integracion.alignetsac.com/VPOS2/js/modalcomercio.js"/>
                </group>
            </group>
        </field>
    </record>
    
    <record id="transaction_form_bncr" model="ir.ui.view">
        <field name="name">BNCR Transaction Form</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.payment_transaction_form" />
        <field name="arch" type="xml">
            <field name="provider_reference" position="after">
                <field name="acquirerId" invisible="provider_code != 'bncr'" />
                <field name="idCommerce" invisible="provider_code != 'bncr'" />
                <field name="purchaseOperationNumber" invisible="provider_code != 'bncr'" />
                <field name="bncr_payment_id" invisible="provider_code != 'bncr'"  />
                <field name="purchaseAmount" invisible="provider_code != 'bncr'"  />
                <field name="purchaseCurrencyCode" invisible="provider_code != 'bncr'"  />
                <field name="purchaseVerification" invisible="provider_code != 'bncr'"  />
                <field name="bncr_refund_id" invisible="provider_code != 'bncr'"  />
                <field name="bncr_refund_amount" invisible="provider_code != 'bncr'"  />
                <field name="bncr_refund_currency" invisible="provider_code != 'bncr'"  />
                <field name="bncr_refund_createdat" invisible="provider_code != 'bncr'"  />
                <field name="reserved1" invisible="provider_code != 'bncr'" />
                <field name="reserved22" invisible="provider_code != 'bncr'" />
                <field name="reserved23" invisible="provider_code != 'bncr'" />
                <field name="urlConfirm" invisible="provider_code != 'bncr'" />
                <field name="urlResponse" invisible="provider_code != 'bncr'" />
            </field>
        </field>
    </record>

</odoo>
